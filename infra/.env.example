# Database
DATABASE_URL=postgresql+asyncpg://stocklisto:stocklisto@db:5432/stocklisto
POSTGRES_USER=stocklisto
POSTGRES_PASSWORD=stocklisto
POSTGRES_DB=stocklisto

# Redis
REDIS_PASSWORD=stocklisto-redis-change-me
REDIS_URL=redis://:stocklisto-redis-change-me@redis:6379/0

# JWT
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# Stock
STOCK_LOCK_TTL_SEC=900
DISPATCH_AUTH_THRESHOLD_UNITS=500
DISPATCH_AUTH_THRESHOLD_AMOUNT=10000.00

# Bootstrap admin (only read on 0002_seed_admin migration)
BOOTSTRAP_ADMIN_PASSWORD=Admin1234!

# Currency
CURRENCY_SYMBOL=Q

# Observability (optional — leave empty to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
